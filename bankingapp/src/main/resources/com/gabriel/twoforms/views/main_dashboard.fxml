<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.controllers.MainDashboardController">
    <!-- Top Navigation -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="20.0" styleClass="top-nav">
            <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                <image>
                    <Image url="@../images/logo.png" />
                </image>
            </ImageView>
            <Label styleClass="logo-text" text="PROSPERA" />
            <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS" spacing="15.0">
                <Label fx:id="userNameLabel" styleClass="text-secondary" text="User Name" />
                <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="button-text" text="Log Out" />
            </HBox>
        </HBox>
    </top>

    <!-- Left Sidebar -->
    <left>
        <VBox prefWidth="250.0" styleClass="sidebar">
            <Label styleClass="text-secondary" text="MAIN MENU">
                <VBox.margin>
                    <Insets bottom="10.0" left="20.0" />
                </VBox.margin>
            </Label>
            <VBox fx:id="sidebarMenu" spacing="5.0">
                <!-- Dynamically populated -->
            </VBox>
        </VBox>
    </left>

    <!-- Dynamic Content Area -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #F8FAFC;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
        </StackPane>
    </center>
</BorderPane>
