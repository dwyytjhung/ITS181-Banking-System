<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="30.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.controllers.DepositWithdrawController">
   <children>
      <Label styleClass="heading-1" text="Deposit &amp; Withdraw" />
      <VBox maxWidth="500.0" spacing="20.0" styleClass="card">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="text-secondary" text="Select Account" />
                  <ComboBox fx:id="accountCombo" maxWidth="1.7976931348623157E308" />
               </children>
            </VBox>
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="text-secondary" text="Amount ($)" />
                  <TextField fx:id="amountField" promptText="0.00" />
               </children>
            </VBox>
            <Label fx:id="statusLabel" managed="false" visible="false" />
            <HBox spacing="15.0">
               <children>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDeposit" styleClass="button-primary" text="Deposit" HBox.hgrow="ALWAYS">
                     <padding>
                        <Insets bottom="12.0" top="12.0" />
                     </padding>
                  </Button>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleWithdraw" styleClass="button-secondary" text="Withdraw" HBox.hgrow="ALWAYS">
                     <padding>
                        <Insets bottom="12.0" top="12.0" />
                     </padding>
                  </Button>
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
