<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="mobile-scroll-container" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.controllers.CustomerCardCenterController">
   <content>
      <VBox spacing="20.0" style="-fx-background-color: transparent;">
         <padding>
            <Insets bottom="20.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label styleClass="heading-2" text="Card Center" style="-fx-font-size: 20px;" />
            
            <!-- Request Form -->
            <VBox spacing="15.0" styleClass="mobile-card">
               <children>
                  <Label text="Request a Card" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #1E293B;" />
                  <VBox spacing="6.0">
                     <children>
                        <Label styleClass="text-secondary" text="Request Type" style="-fx-font-size: 13px;" />
                        <ComboBox fx:id="requestTypeCombo" maxWidth="1.7976931348623157E308" style="-fx-font-size: 13px;" />
                     </children>
                  </VBox>
                  <Label fx:id="statusLabel" managed="false" visible="false" />
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSubmitRequest" styleClass="button-primary" text="Submit Request">
                     <padding><Insets bottom="12.0" top="12.0" /></padding>
                     <VBox.margin><Insets top="5.0" /></VBox.margin>
                  </Button>
               </children>
            </VBox>
            
            <!-- Requests List -->
            <VBox spacing="10.0">
               <children>
                  <Label text="MY REQUESTS" style="-fx-text-fill: #64748B; -fx-font-size: 11px; -fx-font-weight: bold;" />
                  <VBox fx:id="requestsContainer" spacing="10.0">
                     <!-- Dynamically Populated -->
                  </VBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </content>
</ScrollPane>
