<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="mobile-scroll-container" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.controllers.ProfileController">
   <content>
      <VBox fx:id="rootPane" spacing="20.0" style="-fx-background-color: transparent;">
         <padding>
            <Insets bottom="20.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label styleClass="heading-2" text="Profile &amp; Settings" style="-fx-font-size: 20px;" />

            <!-- Avatar Card -->
            <VBox alignment="CENTER" spacing="8.0" styleClass="mobile-card">
               <children>
                  <Label text="👤" style="-fx-font-size: 48px;" />
                  <Label fx:id="fullNameLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="" />
                  <Label fx:id="usernameLabel" styleClass="text-secondary" text="" style="-fx-font-size: 13px;" />
                  <Label fx:id="roleLabel" styleClass="badge-success" text="" style="-fx-font-size: 12px;" />
               </children>
            </VBox>
            
            <!-- Settings Card -->
            <VBox spacing="15.0" styleClass="mobile-card">
               <children>
                  <Label text="SETTINGS" style="-fx-text-fill: #64748B; -fx-font-size: 11px; -fx-font-weight: bold;" />
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label text="View Mode:" style="-fx-font-size: 13px; -fx-text-fill: #1E293B;" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" />
                        <HBox styleClass="toggle-switch-container">
                           <children>
                              <RadioButton fx:id="desktopRadio" mnemonicParsing="false" styleClass="toggle-switch-button" text="Desktop" />
                              <RadioButton fx:id="mobileRadio" mnemonicParsing="false" styleClass="toggle-switch-button" text="Mobile" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>
               </children>
            </VBox>

            <!-- Logout -->
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" styleClass="button-danger" text="Log Out"
                    style="-fx-font-size: 14px;">
               <padding>
                  <Insets bottom="14.0" top="14.0" />
               </padding>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </content>
</ScrollPane>
