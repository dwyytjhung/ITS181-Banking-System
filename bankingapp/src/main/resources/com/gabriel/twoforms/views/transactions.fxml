<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="30.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.controllers.TransactionsController">
   <children>
      <Label styleClass="heading-1" text="Transaction History" />
      <VBox styleClass="card" VBox.vgrow="ALWAYS">
         <children>
            <TableView fx:id="transactionsTable" prefHeight="400.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="dateCol" prefWidth="150.0" text="Date &amp; Time" />
                <TableColumn fx:id="accountCol" prefWidth="150.0" text="Account" />
                <TableColumn fx:id="typeCol" prefWidth="120.0" text="Type" />
                <TableColumn fx:id="amountCol" prefWidth="120.0" text="Amount" />
                <TableColumn fx:id="descCol" prefWidth="300.0" text="Description" />
              </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</VBox>
