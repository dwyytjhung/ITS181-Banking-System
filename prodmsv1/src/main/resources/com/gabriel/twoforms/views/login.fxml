<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootPane" alignment="CENTER" spacing="0"
      styleClass="auth-bg"
      stylesheets="@../css/styles.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gabriel.twoforms.controllers.LoginController">
   <children>

      <VBox alignment="CENTER" spacing="0" VBox.vgrow="ALWAYS" maxWidth="440.0">
         <padding>
            <Insets top="64" bottom="52" />
         </padding>
         <children>

            <!-- ── BRANDING BLOCK ── -->
            <VBox alignment="CENTER" spacing="0">
               <children>

                  <HBox alignment="CENTER">
                     <ImageView fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../images/logo.png" />
                        </image>
                     </ImageView>
                  </HBox>

                  <Label styleClass="auth-brand-wordmark" text="PROSPERA">
                     <VBox.margin><Insets top="16" /></VBox.margin>
                  </Label>

                  <Label styleClass="auth-brand-tagline" text="Grow Smarter. Bank Better.">
                     <VBox.margin><Insets top="8" /></VBox.margin>
                  </Label>

                  <Label fx:id="loginTitle" style="-fx-font-size: 12px; -fx-font-weight: 600; -fx-text-fill: rgba(255,255,255,0.45); -fx-letter-spacing: 1.5;" text="SECURE DIGITAL BANKING">
                     <VBox.margin><Insets top="12" /></VBox.margin>
                  </Label>

               </children>
            </VBox>

            <!-- ── LOGIN CARD ── -->
            <VBox spacing="22.0" styleClass="auth-card">
               <VBox.margin><Insets top="36" /></VBox.margin>
               <children>

                  <!-- Card header -->
                  <VBox spacing="5.0">
                     <Label styleClass="auth-card-title" text="Sign In" />
                     <Label styleClass="auth-card-subtitle" text="Enter your credentials to continue." />
                  </VBox>

                  <!-- Username field -->
                  <VBox spacing="7.0">
                     <children>
                        <Label styleClass="auth-field-label" text="Username" />
                        <TextField fx:id="usernameField" promptText="Enter your username" />
                     </children>
                  </VBox>

                  <!-- Password field -->
                  <VBox spacing="7.0">
                     <children>
                        <Label styleClass="auth-field-label" text="Password" />
                        <PasswordField fx:id="passwordField" promptText="Enter your password" />
                     </children>
                  </VBox>

                  <!-- Error label -->
                  <Label fx:id="errorLabel" styleClass="badge-error" text="" visible="false" managed="false"
                         wrapText="true" maxWidth="1.7976931348623157E308" />

                  <!-- Sign In button -->
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                          onAction="#handleLogin" styleClass="button-primary" text="Sign In">
                     <padding><Insets bottom="13.0" top="13.0" /></padding>
                  </Button>

                  <!-- View mode toggle -->
                  <HBox alignment="CENTER" spacing="14.0">
                     <Label styleClass="text-secondary" text="View Mode:" />
                     <HBox styleClass="toggle-switch-container">
                        <children>
                           <RadioButton fx:id="desktopRadio" mnemonicParsing="false"
                                        styleClass="toggle-switch-button" text="🖥 Desktop" />
                           <RadioButton fx:id="mobileRadio" mnemonicParsing="false"
                                        styleClass="toggle-switch-button" text="📱 Mobile" />
                        </children>
                     </HBox>
                  </HBox>

                  <HBox alignment="CENTER">
                     <Button mnemonicParsing="false" onAction="#handleBack"
                             styleClass="button-text"
                             style="-fx-font-size: 12.5px;"
                             text="← Back to Welcome" />
                  </HBox>

               </children>
            </VBox>

         </children>
      </VBox>

   </children>
</VBox>
