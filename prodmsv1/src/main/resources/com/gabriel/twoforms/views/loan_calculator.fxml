<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="30.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.controllers.LoanCalculatorController">
   <children>
      <Label styleClass="heading-1" text="Loan Calculator" />
      <VBox maxWidth="500.0" spacing="20.0" styleClass="card">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="text-secondary" text="Loan Amount ($)" />
                  <TextField fx:id="amountField" promptText="e.g., 10000" />
               </children>
            </VBox>
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="text-secondary" text="Annual Interest Rate (%)" />
                  <TextField fx:id="rateField" promptText="e.g., 5.5" />
               </children>
            </VBox>
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="text-secondary" text="Duration (Months)" />
                  <TextField fx:id="monthsField" promptText="e.g., 36" />
               </children>
            </VBox>
            <Label fx:id="resultLabel" managed="false" visible="false" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleCalculate" styleClass="button-primary" text="Calculate">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </children>
</VBox>
