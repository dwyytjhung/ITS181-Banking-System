<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootPane" alignment="CENTER" spacing="0"
      styleClass="auth-bg"
      stylesheets="@../css/styles.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gabriel.twoforms.controllers.WelcomeController">
   <children>

      <!-- Centered content wrapper -->
      <VBox alignment="CENTER" spacing="0" VBox.vgrow="ALWAYS" maxWidth="460.0">
         <padding>
            <Insets top="72" bottom="56" />
         </padding>
         <children>

            <!-- ── BRANDING BLOCK ── -->
            <VBox alignment="CENTER" spacing="0">
               <children>

                  <!-- Logo icon -->
                  <HBox alignment="CENTER">
                     <ImageView fitHeight="88.0" fitWidth="88.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../images/logo.png" />
                        </image>
                     </ImageView>
                  </HBox>

                  <!-- PROSPERA wordmark -->
                  <Label styleClass="auth-brand-wordmark" text="PROSPERA">
                     <VBox.margin><Insets top="16" /></VBox.margin>
                  </Label>

                  <!-- Tagline -->
                  <Label styleClass="auth-brand-tagline" text="Grow Smarter. Bank Better.">
                     <VBox.margin><Insets top="8" /></VBox.margin>
                  </Label>

                  <!-- Secure badge -->
                  <HBox alignment="CENTER">
                     <VBox.margin><Insets top="16" /></VBox.margin>
                     <children>
                        <HBox styleClass="auth-secure-badge" spacing="6" alignment="CENTER">
                           <children>
                              <Label text="🔒" style="-fx-font-size: 11px;" />
                              <Label styleClass="auth-secure-text" text="256-bit SSL Encrypted · FDIC Insured" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>

               </children>
            </VBox>

            <!-- ── LOGIN CARD ── -->
            <VBox alignment="CENTER" spacing="20.0" styleClass="auth-card">
               <VBox.margin><Insets top="40" /></VBox.margin>
               <children>

                  <VBox spacing="4">
                     <Label styleClass="auth-card-title" text="Welcome Back" />
                     <Label styleClass="auth-card-subtitle" text="Sign in to manage your accounts and finances." />
                  </VBox>

                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                          onAction="#handleCustomerLogin" styleClass="button-primary"
                          text="Log In to My Account">
                     <VBox.margin><Insets top="4" /></VBox.margin>
                     <padding>
                        <Insets bottom="14.0" top="14.0" />
                     </padding>
                  </Button>

                  <!-- View mode toggle -->
                  <HBox alignment="CENTER" spacing="12.0">
                     <Label styleClass="text-secondary" text="View Mode:" />
                     <HBox styleClass="toggle-switch-container">
                        <children>
                           <RadioButton fx:id="desktopRadio" mnemonicParsing="false"
                                        styleClass="toggle-switch-button" text="🖥 Desktop" />
                           <RadioButton fx:id="mobileRadio" mnemonicParsing="false"
                                        styleClass="toggle-switch-button" text="📱 Mobile" />
                        </children>
                     </HBox>
                  </HBox>

               </children>
            </VBox>

            <!-- Admin link -->
            <HBox alignment="CENTER">
               <VBox.margin><Insets top="24" /></VBox.margin>
               <Button mnemonicParsing="false" onAction="#handleAdminLogin" styleClass="button-text"
                       style="-fx-text-fill: rgba(255,255,255,0.50); -fx-font-size: 12px;"
                       text="Administrator Access →" />
            </HBox>

         </children>
      </VBox>

   </children>
</VBox>
