<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootPane" alignment="CENTER" spacing="0"
      style="-fx-background-color: linear-gradient(to bottom, #2D3748, #3D495E 60%, #4F5D75);"
      stylesheets="@../css/styles.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gabriel.twoforms.controllers.WelcomeController">
   <children>

      <VBox alignment="CENTER" spacing="0" VBox.vgrow="ALWAYS">
         <padding>
            <Insets top="64" bottom="48" left="32" right="32" />
         </padding>
         <children>

            <!-- ── BRANDING ── -->
            <VBox alignment="CENTER" spacing="0">
               <children>
                  <HBox alignment="CENTER">
                     <ImageView fitHeight="76.0" fitWidth="76.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../images/logo.png" />
                        </image>
                     </ImageView>
                  </HBox>
                  <Label styleClass="auth-brand-wordmark" text="PROSPERA" style="-fx-font-size: 28px;">
                     <VBox.margin><Insets top="14" /></VBox.margin>
                  </Label>
                  <Label styleClass="auth-brand-tagline" text="Grow Smarter. Bank Better." style="-fx-font-size: 12.5px;">
                     <VBox.margin><Insets top="6" /></VBox.margin>
                  </Label>
               </children>
            </VBox>

            <!-- ── CARD ── -->
            <VBox alignment="CENTER" spacing="20.0"
                  style="-fx-background-color: white; -fx-background-radius: 22; -fx-padding: 32 28 32 28; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.32), 40, 0, 0, 14);">
               <VBox.margin><Insets top="36" /></VBox.margin>
               <children>

                  <VBox spacing="4">
                     <Label style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #1F2937;" text="Welcome Back" />
                     <Label style="-fx-font-size: 12.5px; -fx-text-fill: #6B7280;" text="Your finances, in your pocket." />
                  </VBox>

                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                          onAction="#handleCustomerLogin" styleClass="button-primary" text="Log In">
                     <VBox.margin><Insets top="4" /></VBox.margin>
                     <padding><Insets bottom="13.0" top="13.0" /></padding>
                  </Button>

                  <HBox alignment="CENTER" spacing="10.0">
                     <Label styleClass="text-secondary" text="View Mode:" style="-fx-font-size: 12px;" />
                     <HBox styleClass="toggle-switch-container">
                        <children>
                           <RadioButton fx:id="desktopRadio" mnemonicParsing="false" styleClass="toggle-switch-button" text="Desktop" />
                           <RadioButton fx:id="mobileRadio" mnemonicParsing="false" styleClass="toggle-switch-button" text="Mobile" />
                        </children>
                     </HBox>
                  </HBox>

               </children>
            </VBox>

            <!-- Admin link -->
            <HBox alignment="CENTER">
               <VBox.margin><Insets top="24" /></VBox.margin>
               <Button mnemonicParsing="false" onAction="#handleAdminLogin" styleClass="button-text"
                       style="-fx-text-fill: rgba(255,255,255,0.50); -fx-font-size: 12.5px;"
                       text="Administrator Access →" />
            </HBox>

         </children>
      </VBox>

   </children>
</VBox>
