<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="30.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.controllers.SavingsGoalsController">
   <children>
      <!-- List Panel -->
      <VBox fx:id="listPanel" spacing="20.0" VBox.vgrow="ALWAYS">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label styleClass="heading-1" text="Savings Vault" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" />
                  <Button mnemonicParsing="false" onAction="#handleShowCreatePanel" styleClass="button-primary" text="+ Create New Goal" />
               </children>
            </HBox>
            <ScrollPane fitToWidth="true" styleClass="mobile-scroll-container" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
               <content>
                  <FlowPane fx:id="goalsContainer" hgap="20.0" vgap="20.0" style="-fx-background-color: transparent;">
                     <!-- Dynamically Populated Card Nodes -->
                  </FlowPane>
               </content>
            </ScrollPane>
         </children>
      </VBox>

      <!-- Create Panel -->
      <VBox fx:id="createPanel" managed="false" visible="false" spacing="20.0" maxWidth="450.0" styleClass="card">
         <children>
            <Button mnemonicParsing="false" onAction="#handleBackToList" styleClass="button-text" text="&lt; Back to Vaults" style="-fx-text-fill: #F58220; -fx-padding: 0;" />
            <Label styleClass="heading-3" text="Create Savings Goal" />
            <VBox spacing="15.0">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label styleClass="text-secondary" text="Goal Name" />
                        <TextField fx:id="newGoalNameField" promptText="e.g., Vacation Fund" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0">
                     <children>
                        <Label styleClass="text-secondary" text="Target Amount ($)" />
                        <TextField fx:id="newGoalTargetField" promptText="1000.00" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0">
                     <children>
                        <Label styleClass="text-secondary" text="Optional Description" />
                        <TextField fx:id="newGoalDescField" promptText="e.g., Trip to Japan" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0">
                     <children>
                        <Label styleClass="text-secondary" text="Optional Target Date (YYYY-MM-DD)" />
                        <TextField fx:id="newGoalDateField" promptText="2026-12-25" />
                     </children>
                  </VBox>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleCreateGoal" styleClass="button-primary" text="Create Vault" />
                  <Label fx:id="createStatusLabel" managed="false" visible="false" />
               </children>
            </VBox>
         </children>
      </VBox>

      <!-- Detail Panel -->
      <HBox fx:id="detailPanel" managed="false" visible="false" spacing="30.0" VBox.vgrow="ALWAYS">
         <children>
            <!-- Left Side Details -->
            <VBox spacing="20.0" HBox.hgrow="ALWAYS">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleBackToList" styleClass="button-text" text="&lt; Back to Vaults" style="-fx-text-fill: #F58220; -fx-padding: 0;" />
                  <VBox spacing="15.0" styleClass="card" VBox.vgrow="ALWAYS">
                     <children>
                        <Label fx:id="detailNameLabel" styleClass="heading-2" text="Goal Name" />
                        <Label fx:id="detailDescLabel" styleClass="text-secondary" text="Goal Description goes here." />
                        
                        <GridPane hgap="20.0" vgap="8.0">
                           <columnConstraints>
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0" />
                              <ColumnConstraints hgrow="ALWAYS" />
                           </columnConstraints>
                           <children>
                              <Label text="Target Amount:" styleClass="text-secondary" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                              <Label fx:id="detailTargetLabel" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="\$0.00" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                              
                              <Label text="Saved Balance:" styleClass="text-secondary" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                              <Label fx:id="detailSavedLabel" style="-fx-font-weight: bold; -fx-text-fill: #22C55E; -fx-font-size: 14px;" text="\$0.00" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                              
                              <Label text="Remaining:" styleClass="text-secondary" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                              <Label fx:id="detailRemainingLabel" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="\$0.00" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                              
                              <Label text="Target Date:" styleClass="text-secondary" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                              <Label fx:id="detailDateLabel" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="N/A" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                              
                              <Label text="Status:" styleClass="text-secondary" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                              <Label fx:id="detailStatusLabel" text="ACTIVE" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                           </children>
                        </GridPane>

                        <ProgressBar fx:id="detailProgressBar" maxWidth="1.7976931348623157E308" progress="0.0" style="-fx-pref-height: 12px;" />
                        
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Label text="Achievement:" styleClass="text-secondary" />
                              <Label fx:id="detailBadgeLabel" text="None" style="-fx-font-weight: bold; -fx-text-fill: #F58220; -fx-font-size: 14px;" />
                           </children>
                        </HBox>

                        <Label text="Goal History" styleClass="heading-3" style="-fx-padding: 10 0 0 0;" />
                        <TableView fx:id="savingsTransactionsTable" prefHeight="200.0" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="stxDateCol" prefWidth="180.0" text="Date &amp; Time" />
                            <TableColumn fx:id="stxTypeCol" prefWidth="100.0" text="Action" />
                            <TableColumn fx:id="stxAmountCol" prefWidth="120.0" text="Amount" />
                            <TableColumn fx:id="stxBalanceCol" prefWidth="150.0" text="Updated Balance" />
                          </columns>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </VBox>

            <!-- Right Side Management Panel -->
            <VBox prefWidth="350.0" spacing="20.0">
               <children>
                  <VBox spacing="15.0" styleClass="card">
                     <children>
                        <Label styleClass="heading-3" text="Manage Vault Funds" />
                        <VBox spacing="5.0">
                           <children>
                              <Label styleClass="text-secondary" text="Transfer Amount ($)" />
                              <TextField fx:id="amountField" promptText="0.00" />
                           </children>
                        </VBox>
                        <HBox spacing="10.0">
                           <children>
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDeposit" styleClass="button-primary" text="Add Money" HBox.hgrow="ALWAYS" />
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleWithdraw" styleClass="button-secondary" text="Withdraw" HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>
                        
                        <Label text="QUICK TRANSFERS" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748B; -fx-padding: 5 0 0 0;" />
                        <GridPane hgap="10.0" vgap="10.0">
                           <columnConstraints>
                              <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                              <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                           </columnConstraints>
                           <children>
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleQuickAdd100" text="+$100" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleQuickAdd500" text="+$500" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleQuickAdd1000" text="+$1,000" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleQuickAdd5000" text="+$5,000" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                           </children>
                        </GridPane>
                        <Label fx:id="actionStatusLabel" managed="false" visible="false" />
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
