<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="30.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.controllers.CustomerCardCenterController">
   <children>
      <Label styleClass="heading-1" text="Debit Card Center" />
      <HBox spacing="30.0">
         <children>
            <VBox prefWidth="350.0" spacing="20.0" styleClass="card">
               <children>
                  <Label styleClass="heading-3" text="Request a Card" />
                  <VBox spacing="5.0">
                     <children>
                        <Label styleClass="text-secondary" text="Request Type" />
                        <ComboBox fx:id="requestTypeCombo" maxWidth="1.7976931348623157E308" />
                     </children>
                  </VBox>
                  <Label fx:id="statusLabel" managed="false" visible="false" />
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSubmitRequest" styleClass="button-primary" text="Submit Request">
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </Button>
               </children>
            </VBox>
            <VBox styleClass="card" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="heading-3" text="My Requests">
                     <VBox.margin>
                        <Insets bottom="15.0" />
                     </VBox.margin>
                  </Label>
                  <TableView fx:id="requestTable" prefHeight="300.0" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="dateCol" prefWidth="120.0" text="Request Date" />
                      <TableColumn fx:id="typeCol" prefWidth="150.0" text="Type" />
                      <TableColumn fx:id="statusCol" prefWidth="120.0" text="Status" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
