<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="30.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.controllers.StatementsController">
   <children>
      <Label styleClass="heading-1" text="Statements &amp; Receipts" />
      <HBox spacing="30.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox prefWidth="300.0" spacing="20.0" styleClass="card">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label styleClass="text-secondary" text="Select Account" />
                        <ComboBox fx:id="accountCombo" maxWidth="1.7976931348623157E308" />
                     </children>
                  </VBox>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleGenerateStatement" styleClass="button-primary" text="View Monthly Statement">
                     <padding>
                        <Insets bottom="12.0" top="12.0" />
                     </padding>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </Button>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleGenerateReceipt" styleClass="button-secondary" text="Get Latest Receipt">
                     <padding>
                        <Insets bottom="12.0" top="12.0" />
                     </padding>
                  </Button>
               </children>
            </VBox>
            <VBox styleClass="card" HBox.hgrow="ALWAYS">
               <children>
                  <TextArea fx:id="documentArea" editable="false" prefHeight="400.0" style="-fx-font-family: 'Courier New'; -fx-font-size: 14px;" wrapText="true" VBox.vgrow="ALWAYS">
                     <font>
                        <Font name="Courier New" size="14.0" />
                     </font>
                  </TextArea>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
