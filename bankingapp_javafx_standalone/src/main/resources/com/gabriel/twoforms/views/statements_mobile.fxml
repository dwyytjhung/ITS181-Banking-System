<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="mobile-scroll-container" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.controllers.StatementsController">
   <content>
      <VBox spacing="20.0" style="-fx-background-color: transparent;">
         <padding>
            <Insets bottom="20.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label styleClass="heading-2" text="Statements &amp; Receipts" style="-fx-font-size: 20px;" />
            <VBox spacing="15.0" styleClass="mobile-card">
               <children>
                  <VBox spacing="6.0">
                     <children>
                        <Label styleClass="text-secondary" text="Select Account" style="-fx-font-size: 13px;" />
                        <ComboBox fx:id="accountCombo" maxWidth="1.7976931348623157E308" style="-fx-font-size: 13px;" />
                     </children>
                  </VBox>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleGenerateStatement" styleClass="button-primary" text="Generate Statement">
                     <padding><Insets bottom="10.0" top="10.0" /></padding>
                  </Button>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleGenerateReceipt" styleClass="button-secondary" text="Generate Receipt">
                     <padding><Insets bottom="10.0" top="10.0" /></padding>
                  </Button>
               </children>
            </VBox>
            <TextArea fx:id="documentArea" editable="false" prefHeight="350.0" promptText="Statement or receipt will appear here..." wrapText="true"
                      style="-fx-font-family: monospace; -fx-font-size: 12px; -fx-background-radius: 12; -fx-border-radius: 12;" />
         </children>
      </VBox>
   </content>
</ScrollPane>
