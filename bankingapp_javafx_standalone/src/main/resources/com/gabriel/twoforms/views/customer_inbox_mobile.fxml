<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox style="-fx-background-color: #F8FAFC;" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.controllers.CustomerInboxController">
   <children>
      <!-- Notification List Pane -->
      <VBox fx:id="notificationListPane" VBox.vgrow="ALWAYS">
         <children>
            <ScrollPane fitToWidth="true" styleClass="mobile-scroll-container" VBox.vgrow="ALWAYS">
               <content>
                  <VBox spacing="20.0" style="-fx-background-color: transparent;">
                     <padding>
                        <Insets bottom="20.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                     <children>
                        <Label styleClass="heading-2" text="Inbox" style="-fx-font-size: 20px;" />
                        <Label fx:id="unreadBadge" styleClass="badge-pending" text="" managed="false" visible="false" />
                        <VBox fx:id="inboxContainer" spacing="10.0">
                           <!-- Dynamically Populated -->
                        </VBox>
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
      
      <!-- Message Detail Pane (toggled on tap) -->
      <VBox fx:id="messagePanel" managed="false" visible="false" VBox.vgrow="ALWAYS">
         <children>
            <ScrollPane fitToWidth="true" styleClass="mobile-scroll-container" VBox.vgrow="ALWAYS">
               <content>
                  <VBox spacing="15.0" style="-fx-background-color: transparent;">
                     <padding>
                        <Insets bottom="20.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                     <children>
                        <Button fx:id="backBtn" mnemonicParsing="false" styleClass="button-text" text="&lt; Back to Inbox"
                                style="-fx-font-size: 13px; -fx-text-fill: #F58220;" />
                        <Label fx:id="messageTitleLabel" styleClass="heading-3" text="" wrapText="true" />
                        <Label fx:id="messageDateLabel" styleClass="text-secondary" text="" style="-fx-font-size: 12px;" />
                        <TextArea fx:id="messageBodyArea" editable="false" prefHeight="300.0" wrapText="true"
                                  style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-font-size: 13px;" />
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</VBox>
