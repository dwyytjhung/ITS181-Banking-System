<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="mobile-scroll-container" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.controllers.TransferController">
   <content>
      <VBox spacing="20.0" style="-fx-background-color: transparent;">
         <padding>
            <Insets bottom="20.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label styleClass="heading-2" text="Transfer Money" style="-fx-font-size: 20px;" />

            <VBox spacing="15.0" styleClass="mobile-card">
               <children>
                  <VBox spacing="6.0">
                     <children>
                        <Label styleClass="text-secondary" text="From Account" style="-fx-font-size: 13px;" />
                        <ComboBox fx:id="fromAccountCombo" maxWidth="1.7976931348623157E308" style="-fx-font-size: 13px;" />
                     </children>
                  </VBox>
                  <VBox spacing="6.0">
                     <children>
                        <Label styleClass="text-secondary" text="To Account Number" style="-fx-font-size: 13px;" />
                        <TextField fx:id="toAccountField" promptText="Enter recipient account number" style="-fx-font-size: 13px; -fx-padding: 10 12;" />
                     </children>
                  </VBox>
                  <VBox spacing="6.0">
                     <children>
                        <Label styleClass="text-secondary" text="Amount ($)" style="-fx-font-size: 13px;" />
                        <TextField fx:id="amountField" promptText="0.00" style="-fx-font-size: 14px; -fx-padding: 10 12;" />
                     </children>
                  </VBox>
                  <VBox spacing="6.0">
                     <children>
                        <Label styleClass="text-secondary" text="Note (optional)" style="-fx-font-size: 13px;" />
                        <TextField fx:id="descriptionField" promptText="e.g. Rent, Bills..." style="-fx-font-size: 13px; -fx-padding: 10 12;" />
                     </children>
                  </VBox>
                  <Label fx:id="statusLabel" managed="false" visible="false" />
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleTransfer" styleClass="button-primary" text="Send Money">
                     <padding>
                        <Insets bottom="12.0" top="12.0" />
                     </padding>
                     <VBox.margin>
                        <Insets top="5.0" />
                     </VBox.margin>
                  </Button>
               </children>
            </VBox>
         </children>
      </VBox>
   </content>
</ScrollPane>
