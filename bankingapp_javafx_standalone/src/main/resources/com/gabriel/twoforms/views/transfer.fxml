<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="30.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.controllers.TransferController">
   <children>
      <Label styleClass="heading-1" text="Transfer Money" />
      <VBox maxWidth="500.0" spacing="20.0" styleClass="card">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="text-secondary" text="From Account" />
                  <ComboBox fx:id="fromAccountCombo" maxWidth="1.7976931348623157E308" />
               </children>
            </VBox>
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="text-secondary" text="To Account Number" />
                  <TextField fx:id="toAccountField" promptText="Enter recipient account number" />
               </children>
            </VBox>
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="text-secondary" text="Amount" />
                  <TextField fx:id="amountField" promptText="0.00" />
               </children>
            </VBox>
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="text-secondary" text="Description (Optional)" />
                  <TextField fx:id="descriptionField" promptText="What is this for?" />
               </children>
            </VBox>
            <Label fx:id="statusLabel" managed="false" visible="false" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleTransfer" styleClass="button-primary" text="Confirm Transfer">
               <padding>
                  <Insets bottom="12.0" top="12.0" />
               </padding>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </children>
</VBox>
