<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="mobile-scroll-container" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.controllers.LoanCalculatorController">
   <content>
      <VBox spacing="20.0" style="-fx-background-color: transparent;">
         <padding>
            <Insets bottom="20.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label styleClass="heading-2" text="Loan Calculator" style="-fx-font-size: 20px;" />
            <VBox spacing="15.0" styleClass="mobile-card">
               <children>
                  <VBox spacing="6.0">
                     <children>
                        <Label styleClass="text-secondary" text="Loan Amount ($)" style="-fx-font-size: 13px;" />
                        <TextField fx:id="amountField" promptText="e.g. 10000" style="-fx-font-size: 13px; -fx-padding: 10 12;" />
                     </children>
                  </VBox>
                  <VBox spacing="6.0">
                     <children>
                        <Label styleClass="text-secondary" text="Annual Interest Rate (%)" style="-fx-font-size: 13px;" />
                        <TextField fx:id="rateField" promptText="e.g. 5.5" style="-fx-font-size: 13px; -fx-padding: 10 12;" />
                     </children>
                  </VBox>
                  <VBox spacing="6.0">
                     <children>
                        <Label styleClass="text-secondary" text="Loan Term (Months)" style="-fx-font-size: 13px;" />
                        <TextField fx:id="monthsField" promptText="e.g. 36" style="-fx-font-size: 13px; -fx-padding: 10 12;" />
                     </children>
                  </VBox>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleCalculate" styleClass="button-primary" text="Calculate">
                     <padding><Insets bottom="12.0" top="12.0" /></padding>
                     <VBox.margin><Insets top="5.0" /></VBox.margin>
                  </Button>
               </children>
            </VBox>
            <VBox spacing="10.0" styleClass="mobile-card">
               <children>
                  <Label text="RESULT" style="-fx-text-fill: #64748B; -fx-font-size: 11px; -fx-font-weight: bold;" />
                  <Label fx:id="resultLabel" text="Fill in the form above to calculate" wrapText="true"
                         style="-fx-font-size: 14px; -fx-text-fill: #1E293B;" />
               </children>
            </VBox>
         </children>
      </VBox>
   </content>
</ScrollPane>
