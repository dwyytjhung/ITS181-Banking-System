<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootPane" alignment="CENTER" maxWidth="600.0" spacing="0.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.controllers.ProfileController">
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>
   <children>
      <!-- Header -->
      <VBox alignment="CENTER" spacing="8.0">
         <children>
            <Label text="👤" style="-fx-font-size: 48px;" />
            <Label fx:id="fullNameLabel" styleClass="heading-1" text="" style="-fx-font-size: 26px;" />
            <Label fx:id="usernameLabel" styleClass="text-secondary" text="" style="-fx-font-size: 14px;" />
            <Label fx:id="roleLabel" styleClass="badge-success" text="" style="-fx-font-size: 12px;" />
         </children>
         <VBox.margin>
            <Insets bottom="30.0" />
         </VBox.margin>
      </VBox>

      <!-- Settings Card -->
      <VBox spacing="20.0" styleClass="card" maxWidth="480.0">
         <children>
            <Label text="SETTINGS" style="-fx-text-fill: #64748B; -fx-font-size: 11px; -fx-font-weight: bold;" />
            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <Label text="View Mode:" style="-fx-font-size: 14px; -fx-text-fill: #1E293B;" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" />
                  <HBox styleClass="toggle-switch-container">
                     <children>
                        <RadioButton fx:id="desktopRadio" mnemonicParsing="false" styleClass="toggle-switch-button" text="Desktop" />
                        <RadioButton fx:id="mobileRadio" mnemonicParsing="false" styleClass="toggle-switch-button" text="Mobile" />
                     </children>
                  </HBox>
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
         </padding>
      </VBox>

      <!-- Logout -->
      <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="button-danger" text="Log Out" maxWidth="480.0"
              style="-fx-font-size: 14px;">
         <padding>
            <Insets bottom="14.0" top="14.0" />
         </padding>
         <VBox.margin>
            <Insets top="25.0" />
         </VBox.margin>
      </Button>
   </children>
</VBox>
